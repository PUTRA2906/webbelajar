<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>WebBelajar</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f8f9fa;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      touch-action: none;
    }

    /* ── Toolbar ── */
    #toolbar {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 6px 8px;
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
      z-index: 10;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
      flex-shrink: 0;
    }
    #toolbar::-webkit-scrollbar { display: none; }

    .tool-group {
      display: flex;
      gap: 2px;
      padding: 0 6px;
      border-right: 1px solid #e0e0e0;
      flex-shrink: 0;
    }
    .tool-group:last-child { border-right: none; }

    .tool-btn {
      width: 40px; height: 40px;
      border: 1.5px solid transparent;
      border-radius: 8px;
      background: transparent;
      cursor: pointer;
      font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      transition: background .15s, border-color .15s;
      flex-shrink: 0;
      user-select: none;
    }
    .tool-btn:active { background: #e8f0fe; }
    .tool-btn.active { background: #e8f0fe; border-color: #4285f4; }

    #colorPicker {
      width: 40px; height: 40px;
      border: 1.5px solid #ccc;
      border-radius: 8px;
      padding: 3px;
      cursor: pointer;
      background: none;
      flex-shrink: 0;
    }

    #strokeSize {
      width: 70px;
      accent-color: #4285f4;
      flex-shrink: 0;
    }

    #appTitle {
      font-weight: 700;
      font-size: 14px;
      color: #333;
      margin-right: 4px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    #usersBar {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .user-badge {
      display: flex;
      align-items: center;
      gap: 3px;
      padding: 3px 8px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      color: #fff;
      white-space: nowrap;
    }
    .user-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: rgba(255,255,255,.7);
    }

    /* ── Canvas area ── */
    #canvasWrapper {
      flex: 1;
      position: relative;
      overflow: hidden;
      cursor: crosshair;
      touch-action: none;
    }

    canvas {
      position: absolute;
      top: 0; left: 0;
      touch-action: none;
    }

    /* ── Remote cursors ── */
    .remote-cursor {
      position: absolute;
      pointer-events: none;
      z-index: 20;
      transform: translate(-2px, -2px);
      transition: left .05s, top .05s;
    }
    .cursor-label {
      position: absolute;
      top: 20px; left: 8px;
      background: var(--c);
      color: #fff;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 6px;
      border-radius: 4px;
      white-space: nowrap;
    }

    /* ── Status bar (hidden on small screens) ── */
    #statusBar {
      padding: 3px 10px;
      background: #fff;
      border-top: 1px solid #e0e0e0;
      font-size: 11px;
      color: #888;
      display: flex;
      gap: 12px;
      flex-shrink: 0;
    }
    @media (max-width: 480px) {
      #statusBar { display: none; }
      #appTitle  { display: none; }
    }
  </style>
</head>
<body>

<div id="toolbar">
  <span id="appTitle">✏️ WebBelajar</span>

  <div class="tool-group">
    <button class="tool-btn active" data-tool="pen"     title="Pen">✏️</button>
    <button class="tool-btn"        data-tool="line"    title="Line">╱</button>
    <button class="tool-btn"        data-tool="rect"    title="Rect">▭</button>
    <button class="tool-btn"        data-tool="ellipse" title="Ellipse">⬭</button>
    <button class="tool-btn"        data-tool="text"    title="Text">T</button>
    <button class="tool-btn"        data-tool="eraser"  title="Eraser">🧹</button>
  </div>

  <div class="tool-group">
    <input type="color" id="colorPicker" value="#1a1a2e" title="Color">
    <input type="range" id="strokeSize" min="1" max="30" value="3" title="Size">
  </div>

  <div class="tool-group">
    <button class="tool-btn" id="btnUndo"  title="Undo">↩️</button>
    <button class="tool-btn" id="btnClear" title="Clear">🗑️</button>
  </div>

  <div id="usersBar"></div>
</div>

<div id="canvasWrapper">
  <canvas id="mainCanvas"></canvas>
  <canvas id="previewCanvas"></canvas>
</div>

<div id="statusBar">
  <span id="statusTool">Tool: Pen</span>
  <span id="statusCoords">x: 0, y: 0</span>
  <span id="statusConn">⚪ Connecting…</span>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const wrapper       = document.getElementById('canvasWrapper');
const mainCanvas    = document.getElementById('mainCanvas');
const previewCanvas = document.getElementById('previewCanvas');
const mainCtx       = mainCanvas.getContext('2d');
const previewCtx    = previewCanvas.getContext('2d');

// ── Resize ──
function resizeCanvases() {
  const w = wrapper.clientWidth, h = wrapper.clientHeight;
  const img = mainCtx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  [mainCanvas, previewCanvas].forEach(c => { c.width = w; c.height = h; });
  mainCtx.putImageData(img, 0, 0);
}
resizeCanvases();
window.addEventListener('resize', resizeCanvases);

// ── State ──
let tool = 'pen', color = '#1a1a2e', size = 3;
let drawing = false, startX = 0, startY = 0;
let penPath = [];
let selfId = null;
const remoteCursors = {};
const elements = [];

// ── Toolbar ──
document.querySelectorAll('.tool-btn[data-tool]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tool-btn[data-tool]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    tool = btn.dataset.tool;
    previewCanvas.style.cursor = tool === 'text' ? 'text' : 'crosshair';
    document.getElementById('statusTool').textContent = 'Tool: ' + btn.title;
  });
});
document.getElementById('colorPicker').addEventListener('input', e => color = e.target.value);
document.getElementById('strokeSize').addEventListener('input', e => size = +e.target.value);
document.getElementById('btnUndo').addEventListener('click', () => socket.emit('canvas:undo'));
document.getElementById('btnClear').addEventListener('click', () => {
  if (confirm('Hapus semua gambar?')) socket.emit('canvas:clear');
});
document.addEventListener('keydown', e => {
  if (e.ctrlKey && e.key === 'z') { socket.emit('canvas:undo'); return; }
  const map = { p:'pen', l:'line', r:'rect', e:'ellipse', t:'text', x:'eraser' };
  if (!e.ctrlKey && map[e.key]) document.querySelector(`[data-tool="${map[e.key]}"]`)?.click();
});

// ── Draw helpers ──
function applyStyle(ctx, el) {
  ctx.strokeStyle = el.tool === 'eraser' ? '#ffffff' : el.color;
  ctx.lineWidth   = el.tool === 'eraser' ? el.size * 4 : el.size;
  ctx.lineCap = ctx.lineJoin = 'round';
}

function drawElement(ctx, el) {
  ctx.save();
  applyStyle(ctx, el);
  switch (el.tool) {
    case 'pen': case 'eraser':
      if (!el.path || el.path.length < 2) break;
      ctx.beginPath();
      ctx.moveTo(el.path[0].x, el.path[0].y);
      el.path.forEach(p => ctx.lineTo(p.x, p.y));
      ctx.stroke();
      break;
    case 'line':
      ctx.beginPath(); ctx.moveTo(el.x1, el.y1); ctx.lineTo(el.x2, el.y2); ctx.stroke();
      break;
    case 'rect':
      ctx.strokeRect(el.x, el.y, el.w, el.h);
      break;
    case 'ellipse':
      ctx.beginPath();
      ctx.ellipse(el.cx, el.cy, Math.abs(el.rx), Math.abs(el.ry), 0, 0, Math.PI * 2);
      ctx.stroke();
      break;
    case 'text':
      ctx.font = `${el.size * 5 + 10}px Segoe UI, sans-serif`;
      ctx.fillStyle = el.color;
      // Support multiline
      el.text.split('\n').forEach((line, i) => ctx.fillText(line, el.x, el.y + i * (el.size * 5 + 12)));
      break;
  }
  ctx.restore();
}

function redrawAll() {
  mainCtx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);
  elements.forEach(el => drawElement(mainCtx, el));
}

function buildElement(x2, y2) {
  switch (tool) {
    case 'line':    return { tool, color, size, x1: startX, y1: startY, x2, y2 };
    case 'rect':    return { tool, color, size, x: startX, y: startY, w: x2-startX, h: y2-startY };
    case 'ellipse': return { tool, color, size, cx:(startX+x2)/2, cy:(startY+y2)/2, rx:(x2-startX)/2, ry:(y2-startY)/2 };
    default: return null;
  }
}

// ── Inline text input ──
let textEditorOpen = false;
function openTextInput(x, y) {
  if (textEditorOpen) return;
  textEditorOpen = true;
  const fontSize = Math.max(14, size * 5 + 10);
  const snapColor = color, snapSize = size;

  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:absolute;inset:0;z-index:29;';

  const editor = document.createElement('textarea');
  editor.rows = 1;
  editor.spellcheck = false;
  Object.assign(editor.style, {
    position: 'absolute',
    left: x + 'px',
    top: (y - fontSize) + 'px',
    minWidth: '120px',
    maxWidth: (wrapper.clientWidth - x - 12) + 'px',
    font: `${fontSize}px Segoe UI, sans-serif`,
    color: snapColor,
    background: 'rgba(255,255,255,0.95)',
    border: '2px dashed ' + snapColor,
    borderRadius: '4px',
    padding: '2px 6px',
    outline: 'none',
    resize: 'none',
    overflow: 'hidden',
    zIndex: '30',
    lineHeight: '1.3',
  });

  wrapper.appendChild(overlay);
  wrapper.appendChild(editor);
  // Small delay so touch events don't immediately blur
  setTimeout(() => editor.focus(), 50);

  editor.addEventListener('input', () => {
    editor.style.height = 'auto';
    editor.style.height = editor.scrollHeight + 'px';
  });

  function commit() {
    if (!textEditorOpen) return;
    textEditorOpen = false;
    const text = editor.value.trim();
    overlay.remove(); editor.remove();
    if (!text) return;
    const el = { tool: 'text', color: snapColor, size: snapSize, x, y, text };
    elements.push(el);
    drawElement(mainCtx, el);
    socket.emit('shape:add', el);
  }
  function cancel() {
    if (!textEditorOpen) return;
    textEditorOpen = false;
    overlay.remove(); editor.remove();
  }

  editor.addEventListener('keydown', e => {
    e.stopPropagation();
    if (e.key === 'Escape') { cancel(); return; }
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); commit(); }
  });
  overlay.addEventListener('mousedown', commit);
  overlay.addEventListener('touchstart', commit, { passive: true });
}

// ── Unified pointer position ──
function getPos(e) {
  const r = previewCanvas.getBoundingClientRect();
  const src = e.changedTouches ? e.changedTouches[0] : (e.touches ? e.touches[0] : e);
  return { x: src.clientX - r.left, y: src.clientY - r.top };
}

// ── Pointer down ──
function onPointerDown(e) {
  if (textEditorOpen) return;
  e.preventDefault();
  const { x, y } = getPos(e);
  drawing = true; startX = x; startY = y;

  if (tool === 'text') {
    drawing = false;
    openTextInput(x, y);
    return;
  }
  if (tool === 'pen' || tool === 'eraser') {
    penPath = [{ x, y }];
    socket.emit('draw:start', { x, y, color, size, tool });
  }
}

// ── Pointer move ──
function onPointerMove(e) {
  if (textEditorOpen) return;
  e.preventDefault();
  const { x, y } = getPos(e);
  document.getElementById('statusCoords').textContent = `x: ${Math.round(x)}, y: ${Math.round(y)}`;
  socket.emit('cursor:move', { x, y });
  if (!drawing) return;

  if (tool === 'pen' || tool === 'eraser') {
    penPath.push({ x, y });
    if (penPath.length >= 2) {
      const prev = penPath[penPath.length - 2];
      mainCtx.save();
      mainCtx.strokeStyle = tool === 'eraser' ? '#ffffff' : color;
      mainCtx.lineWidth   = tool === 'eraser' ? size * 4 : size;
      mainCtx.lineCap = mainCtx.lineJoin = 'round';
      mainCtx.beginPath();
      mainCtx.moveTo(prev.x, prev.y);
      mainCtx.lineTo(x, y);
      mainCtx.stroke();
      mainCtx.restore();
    }
    socket.emit('draw:move', { x, y, color, size, tool });
  } else {
    previewCtx.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
    const el = buildElement(x, y);
    if (el) drawElement(previewCtx, el);
  }
}

// ── Pointer up ──
function onPointerUp(e) {
  if (!drawing) return;
  e.preventDefault();
  drawing = false;
  previewCtx.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
  const { x, y } = getPos(e);

  if (tool === 'pen' || tool === 'eraser') {
    const el = { tool, color, size, path: penPath };
    elements.push(el);
    socket.emit('draw:end', el);
    penPath = [];
  } else {
    const el = buildElement(x, y);
    if (el) { elements.push(el); drawElement(mainCtx, el); socket.emit('shape:add', el); }
  }
}

// Mouse events
previewCanvas.addEventListener('mousedown',  onPointerDown);
previewCanvas.addEventListener('mousemove',  onPointerMove);
previewCanvas.addEventListener('mouseup',    onPointerUp);
previewCanvas.addEventListener('mouseleave', e => {
  if (drawing && (tool === 'pen' || tool === 'eraser')) {
    drawing = false;
    const el = { tool, color, size, path: penPath };
    elements.push(el); socket.emit('draw:end', el); penPath = [];
  }
});

// Touch events
previewCanvas.addEventListener('touchstart',  onPointerDown, { passive: false });
previewCanvas.addEventListener('touchmove',   onPointerMove, { passive: false });
previewCanvas.addEventListener('touchend',    onPointerUp,   { passive: false });
previewCanvas.addEventListener('touchcancel', onPointerUp,   { passive: false });

// ── Remote cursors ──
function getOrCreateCursor(id, c, name) {
  if (remoteCursors[id]) return remoteCursors[id];
  const div = document.createElement('div');
  div.className = 'remote-cursor';
  div.innerHTML = `<svg width="16" height="20" viewBox="0 0 16 20">
    <path d="M0 0 L0 16 L4 12 L7 19 L9 18 L6 11 L11 11 Z" fill="${c}" stroke="#fff" stroke-width="1"/>
  </svg><div class="cursor-label" style="--c:${c}">${name}</div>`;
  wrapper.appendChild(div);
  remoteCursors[id] = div;
  return div;
}

// ── Socket.io ──
const socket = io();

socket.on('connect',    () => document.getElementById('statusConn').textContent = '🟢 Terhubung');
socket.on('disconnect', () => document.getElementById('statusConn').textContent = '🔴 Terputus');

socket.on('user:self', ({ id, color: c, name }) => {
  selfId = id;
  document.getElementById('statusConn').textContent = `🟢 ${name} (kamu)`;
});

socket.on('users:update', users => {
  document.getElementById('usersBar').innerHTML = users.map(u =>
    `<div class="user-badge" style="background:${u.color}">
      <div class="user-dot"></div>${u.name}${u.id === selfId ? ' ✓' : ''}
    </div>`
  ).join('');
});

socket.on('canvas:init', els => {
  elements.length = 0; elements.push(...els); redrawAll();
});
socket.on('canvas:clear', () => {
  elements.length = 0;
  mainCtx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);
});

const remotePen = {};
socket.on('draw:start', () => {});
socket.on('draw:move', ({ x, y, color: c, size: s, tool: t }) => {
  mainCtx.save();
  mainCtx.strokeStyle = t === 'eraser' ? '#ffffff' : c;
  mainCtx.lineWidth   = t === 'eraser' ? s * 4 : s;
  mainCtx.lineCap = mainCtx.lineJoin = 'round';
  if (remotePen._last) {
    mainCtx.beginPath();
    mainCtx.moveTo(remotePen._last.x, remotePen._last.y);
    mainCtx.lineTo(x, y);
    mainCtx.stroke();
  }
  mainCtx.restore();
  remotePen._last = { x, y };
});
socket.on('draw:end', el => { remotePen._last = null; elements.push(el); });
socket.on('shape:add', el => { elements.push(el); drawElement(mainCtx, el); });

socket.on('cursor:update', ({ id, x, y, color: c, name }) => {
  const el = getOrCreateCursor(id, c, name);
  el.style.left = x + 'px'; el.style.top = y + 'px';
});
socket.on('cursor:remove', id => { remoteCursors[id]?.remove(); delete remoteCursors[id]; });
</script>
</body>
</html>
